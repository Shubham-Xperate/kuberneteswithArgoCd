# Local .terraform directories
**/.terraform/*

# Terraform lock file is generally fine to commit for reproducibility, but
# some teams exclude it - uncomment if you prefer that:
# .terraform.lock.hcl

# Terraform state files - contain resource IDs/attributes and sometimes
# sensitive values; must never be committed. Use a remote backend instead.
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# tfvars files can contain sensitive values (subscription-specific
# settings) - ignore all of them EXCEPT the committed .example templates.
*.tfvars
*.tfvars.json
!*.tfvars.example
!*.tfvars.json.example

# Override files are never committed
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files that may contain credentials
.terraformrc
terraform.rc
